# ── Provider mode ────────────────────────────────────────────────────────────
# LLM_PROVIDER  : "openai"  → standard OpenAI API (platform.openai.com)
#                 "azure"   → Azure OpenAI
# SEARCH_PROVIDER: "local"  → cosine similarity on a local JSON file (no Azure needed)
#                  "azure"  → Azure AI Search
LLM_PROVIDER=openai
SEARCH_PROVIDER=local

# ── Standard OpenAI (used when LLM_PROVIDER=openai) ──────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL_GPT4O=gpt-4o
OPENAI_MODEL_EMBEDDING=text-embedding-3-large

# ── Azure OpenAI (used when LLM_PROVIDER=azure) ───────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large

# ── Azure AI Search (used when SEARCH_PROVIDER=azure) ────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<your-key>
AZURE_SEARCH_INDEX_NAME=immunisation-guidelines

# ── Local search (used when SEARCH_PROVIDER=local) ───────────────────────────
LOCAL_CHUNKS_FILE=data/chunks_with_embeddings.json

# ── Azure Blob Storage (optional) ────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=<your-connection-string>
AZURE_STORAGE_CONTAINER=immunisation-docs

# ── Azure Document Intelligence (optional) ───────────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=<your-key>
